# Source this file before running any AI tool to route its traffic through mitmproxy:
#   source proxy.env
#
# One-time setup: create JKS truststore for JVM tools (Junie).
# Start from the default Java cacerts so standard CAs remain trusted,
# then add the mitmproxy CA on top.
# ⚠️  Change TRUSTSTORE_PASSWORD to something other than "changeit"!
#
#   TRUSTSTORE_PASSWORD="your-secret-password"
#   CACERTS=$(java -XshowSettings:property -version 2>&1 | grep java.home | awk '{print $NF}')/lib/security/cacerts
#   cp "$CACERTS" ~/.mitmproxy/mitmproxy-truststore.jks
#   keytool -importcert -alias mitmproxy \
#     -file ~/.mitmproxy/mitmproxy-ca-cert.pem \
#     -keystore ~/.mitmproxy/mitmproxy-truststore.jks \
#     -storepass "$TRUSTSTORE_PASSWORD" -noprompt

# ── Generic (Claude Code, Codex CLI, Pi, curl, Python) ───────────────────────
export HTTP_PROXY=http://localhost:8080
export HTTPS_PROXY=http://localhost:8080
export NODE_EXTRA_CA_CERTS=~/.mitmproxy/mitmproxy-ca-cert.pem   # Node.js tools (Claude Code, Codex, Pi)
export SSL_CERT_FILE=~/.mitmproxy/mitmproxy-ca-cert.pem          # Python/curl tools
export REQUESTS_CA_BUNDLE=~/.mitmproxy/mitmproxy-ca-cert.pem     # Python requests

# ── Junie (JVM) ──────────────────────────────────────────────────────────────
# ⚠️  Set TRUSTSTORE_PASSWORD to the password you used when creating the truststore above.
TRUSTSTORE_PASSWORD="changeit"
export JAVA_TOOL_OPTIONS="-Dhttp.proxyHost=localhost -Dhttp.proxyPort=8080 \
  -Dhttps.proxyHost=localhost -Dhttps.proxyPort=8080 \
  -Djavax.net.ssl.trustStore=${HOME}/.mitmproxy/mitmproxy-truststore.jks \
  -Djavax.net.ssl.trustStorePassword=${TRUSTSTORE_PASSWORD}"
